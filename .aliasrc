# editor
alias vi='$EDITOR'
alias vim='$EDITOR'
#alias nv='~/.vimrc'
alias nv='$EDITOR ~/.config/nvim/init.lua'

# tmux
alias t='tmux new-session -A -s TMUX'

# rlwraps
alias coqtop='rlwrap coqtop'
alias sml='rlwrap sml'
alias poly='rlwrap poly'
alias ocaml='rlwrap ocaml'

# fil-c
alias filc='/opt/filc-0.674-linux-x86_64/build/bin/clang'
alias filc++='/opt/filc-0.674-linux-x86_64/build/bin/clang++'

# idf
alias idfinit='. /opt/esp-idf/export.sh'
alias idfrun='idfinit && idf.py build && idf.py flash && idf.py monitor'

# environments
alias cargoinit='. $HOME/.cargo/env'
alias opaminit='[[ ! -r /home/giovanni/.opam/opam-init/init.zsh ]] || source /home/giovanni/.opam/opam-init/init.zsh > /dev/null 2> /dev/null'
alias nvminit='[ -s "$HOME/.nvm/nvm.sh" ] && \. "$HOME/.nvm/nvm.sh" && [ -s "$HOME/.nvm/bash_completion" ] && \. "$HOME/.nvm/bash_completion"'

# python3 venv
alias venv='python3 -m venv'
alias venvinit='python3 -m venv .venv'
alias venvactivate='source .venv/bin/activate'

# git
alias gitu='git add . && git commit && git push'

# homebrew
alias brewp='brew pin'
alias brewsp='brew list --pinned'
alias bubo='brew update && brew outdated'
alias bubc='brew upgrade && brew cleanup'
alias bubu='bubo && bubc'
alias buf='brew upgrade --formula'
alias bcubo='brew update && brew outdated --cask'
alias bcubc='brew upgrade --cask && brew cleanup'

# pacman
alias autoremove='sudo pacman -Qdtq | sudo pacman -Rs -'

# arcuino-cli
alias ardcomp='arduino-cli compile -b arduino:avr:uno -v'
alias ardupl='arduino-cli upload -p /dev/ttyACM0 -b arduino:avr:uno'

# system programs
alias speed='speedtest'
alias q='exit'
alias e='exit'
alias f='lf'

# colored commands
if [[ $(uname) == 'Darwin' ]]
then
  alias ls='ls -G'
else
  alias ls='ls --color=auto'
  alias ip='ip --color=auto'
fi
alias l='ls -l'
alias ll='ls -alh'
alias grep='grep --color=auto'
